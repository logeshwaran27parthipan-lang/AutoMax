generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  triggers    Json?
  steps       Json?
  createdAt   DateTime @default(now()) @map("created_at")
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  @@map("workflows")
}

model Lead {
  id        String   @id @default(uuid())
  email     String?
  name      String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String?
  createdAt DateTime   @default(now()) @map("created_at")
  workflows Workflow[]

  @@map("users")
}
