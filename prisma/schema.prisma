generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// GitHub Copilot: Add a boolean field `isActive` with a default of true
// to the Workflow model. This lets users disable workflows without deleting them.
// Keep all existing fields unchanged.
model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  triggers    Json?
  steps       Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  orgId       String?  @map("org_id")
  org         Organization?  @relation(fields: [orgId], references: [id])
  runs        WorkflowRun[]

  @@map("workflows")
}

model Lead {
  id        String   @id @default(uuid())
  email     String?
  name      String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String?
  createdAt DateTime   @default(now()) @map("created_at")
  workflows Workflow[]
  conversations Conversation[]
  workflowRuns  WorkflowRun[]
  orgMemberships OrganizationMember[]

  @@map("users")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  message   String
  role      String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("conversations")
}

model WorkflowRun {
  id         String           @id @default(uuid())
  workflowId String           @map("workflow_id")
  userId     String           @map("user_id")
  status     String           @default("running")
  trigger    String?
  payload    Json?
  startedAt  DateTime         @default(now()) @map("started_at")
  finishedAt DateTime?        @map("finished_at")
  workflow   Workflow         @relation(fields: [workflowId], references: [id])
  user       User             @relation(fields: [userId], references: [id])
  orgId      String?          @map("org_id")
  org        Organization?    @relation(fields: [orgId], references: [id])
  steps      WorkflowRunStep[]

  @@map("workflow_runs")
}

model WorkflowRunStep {
  id          String      @id @default(uuid())
  runId       String      @map("run_id")
  stepIndex   Int         @map("step_index")
  stepType    String      @map("step_type")
  status      String      @default("pending")
  input       Json?
  output      Json?
  error       String?
  executedAt  DateTime    @default(now()) @map("executed_at")
  run         WorkflowRun @relation(fields: [runId], references: [id])

  @@map("workflow_run_steps")
}

model Organization {
  id        String               @id @default(uuid())
  name      String
  apiKey    String               @unique
  createdAt DateTime             @default(now()) @map("created_at")
  planId             String?              @map("plan_id")
  subscriptionId     String?              @map("subscription_id")
  subscriptionStatus String?              @default("free") @map("subscription_status")
  members   OrganizationMember[]
  workflows Workflow[]
  runs      WorkflowRun[]

  @@map("organizations")
}

model OrganizationMember {
  id        String       @id @default(uuid())
  orgId     String       @map("org_id")
  userId    String       @map("user_id")
  role      String       @default("OWNER")
  createdAt DateTime     @default(now()) @map("created_at")
  org       Organization @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@map("organization_members")
}